# LeetCode Session Cookie
LEETCODE_SESSION=your_leetcode_session_cookie_here

# GitHub Personal Access Token
GITHUB_TOKEN=your_github_token_here

# Target Repository (where solutions will be pushed)
TARGET_REPO=your-username/leetcode-solutions

# AI Provider Selection
# Options: groq (recommended), gemini, auto
# - groq: Use Groq API (14,400 req/day FREE)
# - gemini: Use Gemini API (20 req/day free tier)
# - auto: Try Groq first, fallback to Gemini
AI_PROVIDER=groq

# Groq API Key (RECOMMENDED - Get free key at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (Fallback - Get at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# AI Retry Configuration (optional)
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY=5
SUBMISSION_DELAY=2
